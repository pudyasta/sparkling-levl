{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
      "noUnusedLocals": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "composite": true,

    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "erasableSyntaxOnly": false,

    "lib": ["es2023"],
    "target": "es2022",

    "noEmit": true,
  },
  
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}

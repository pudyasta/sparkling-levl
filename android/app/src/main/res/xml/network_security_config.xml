<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
  <!-- Allow cleartext HTTP to localhost and the Android emulator host alias
       so the Rspeedy dev server (default port 5969) is reachable in debug builds. -->
  <domain-config cleartextTrafficPermitted="true">
    <domain includeSubdomains="false">ta-trpl.web.app</domain>
    <domain includeSubdomains="false">10.0.2.2</domain>
  </domain-config>
</network-security-config>
